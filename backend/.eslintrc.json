{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-useless-catch": "off",
    "no-self-assign": "warn",
    "no-useless-escape": "warn",
    "no-constant-condition": "warn",
    "no-redeclare": "warn"
  }
}
