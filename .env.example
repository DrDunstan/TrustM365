# TrustM365 Environment Configuration
# Copy this file to .env and fill in ENCRYPTION_KEY

# Required: Generate with: npm run generate:key
ENCRYPTION_KEY=your_64_char_hex_key_here

# Path to the SQLite database file (created automatically on first run)
DATABASE_PATH=./data/trustm365.db

# Backend port (Azure App Service requires 8080)
PORT=3001

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# Set to 'production' for hosted deployments
NODE_ENV=development

# Optional: CORS — only needed when frontend and backend are on separate origins
# (e.g. two separate Azure App Services). Leave blank when using Docker/nginx
# (nginx proxies /api to the backend on the same origin so CORS is not needed).
# Example: FRONTEND_URL=https://trustm365.yourdomain.com
FRONTEND_URL=
